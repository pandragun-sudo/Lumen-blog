---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Hero Section */
			.hero {
				padding: 4rem 1rem 3rem;
				text-align: center;
				background: linear-gradient(135deg, rgba(30, 41, 59, 0.03) 0%, rgba(15, 23, 42, 0.08) 100%);
				border-bottom: 1px solid rgba(0,0,0,0.05);
				margin-bottom: 3rem;
			}
			.hero h1 {
				font-size: 3rem;
				font-weight: 800;
				margin-bottom: 1rem;
				background: linear-gradient(90deg, #1e293b 0%, #3b82f6 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				letter-spacing: -0.03em;
			}
			.hero p {
				font-size: 1.2rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto;
				line-height: 1.6;
			}
			
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 1em 4em;
			}
			.blog-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2.5rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.blog-grid li {
				display: flex;
				flex-direction: column;
				transition: transform 0.3s ease, box-shadow 0.3s ease;
				background: var(--bg);
				border-radius: 16px;
				overflow: hidden;
				border: 1px solid var(--border-light);
			}
			.blog-grid li:hover {
				transform: translateY(-5px);
				box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
			}
			
			/* Hero Article (First Post) */
			.blog-grid li:first-child {
				grid-column: 1 / -1; /* Spans all 3 columns */
				margin-bottom: 2rem;
				border: none;
				background: linear-gradient(180deg, var(--bg) 0%, var(--bg-light) 100%);
				border-radius: 24px;
				overflow: hidden;
				box-shadow: 0 4px 20px rgba(0,0,0,0.04);
			}
			.blog-grid li:first-child:hover {
				transform: translateY(-5px);
				box-shadow: 0 16px 32px rgba(0,0,0,0.1);
			}
			.blog-grid li:first-child img {
				width: 100%;
				height: 100%;
				aspect-ratio: 16/9;
				object-fit: cover;
			}
			.blog-grid li:first-child .post-content {
				padding: 3rem;
			}
			.blog-grid li:first-child .title {
				font-size: 2rem;
				margin-bottom: 1rem;
				font-weight: 800;
				letter-spacing: -0.02em;
				display: block;
				-webkit-line-clamp: unset;
			}
			.blog-grid li:first-child .description {
				font-size: 1.15rem;
				line-height: 1.7;
				margin-bottom: 1.5rem;
				display: block;
				-webkit-line-clamp: unset;
			}
			
			/* Regular Articles */
			.blog-grid li:not(:first-child) img {
				width: 100%;
				aspect-ratio: 16/9;
				object-fit: cover;
				border-bottom: 1px solid var(--border-light);
			}
			.blog-grid li:not(:first-child) .post-content {
				padding: 1.5rem;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: var(--text-main);
				font-size: 1.4rem;
				line-height: 1.4;
				font-weight: 700;
				transition: color 0.2s;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.description {
				color: var(--text-muted);
				font-size: 1rem;
				line-height: 1.6;
				margin-top: 0.5rem;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.date {
				margin: 1rem 0 0;
				color: var(--text-light);
				font-size: 0.9rem;
				font-weight: 500;
			}
			
			/* Links */
			.blog-grid li a {
				display: flex;
				flex-direction: column;
				height: 100%;
				text-decoration: none;
				color: inherit;
			}
			.blog-grid li:first-child a {
				display: grid;
				grid-template-columns: 1.2fr 1fr;
				align-items: center;
			}
			
			@media (max-width: 900px) {
				.blog-grid {
					grid-template-columns: repeat(2, 1fr);
				}
				.blog-grid li:first-child {
					grid-template-columns: 1fr;
				}
				.blog-grid li:first-child a {
					flex-direction: column;
				}
				.blog-grid li:first-child .post-content {
					padding: 2rem;
				}
				.blog-grid li:first-child .title {
					font-size: 1.8rem;
				}
			}
			@media (max-width: 600px) {
				.hero {
					padding: 3rem 1rem 2rem;
				}
				.hero h1 {
					font-size: 2.2rem;
				}
				.blog-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		
		<section class="hero">
			<h1>Lumen Insights Blog</h1>
			<p>데이터가 증명하는 유튜브 쇼츠 성장 전략과 크리에이터를 위한 인사이트</p>
		</section>

		<main>
			<ul class="blog-grid">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<Image width={800} height={450} src={post.data.heroImage} alt="" />
								)}
								<div class="post-content">
									<h4 class="title">{post.data.title}</h4>
									<p class="description">{post.data.description}</p>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
