---
const today = new Date();
---

<footer>
	<div class="footer-content">
		&copy; {today.getFullYear()} Lumen Insights. All rights reserved.
	</div>
	
	<!-- Floating Chat Button -->
	<a href="https://t.me/LumenInsightsBot" target="_blank" rel="noopener noreferrer" class="floating-tg-btn" title="텔레그램 봇 문의하기">
		<svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
			<path d="M12 2C6.477 2 2 6.03 2 11c0 2.84 1.5 5.38 3.82 7.04l-1.34 3.4c-.16.4.24.78.62.6l3.52-1.63c1.05.3 2.16.46 3.33.46 5.523 0 10-4.03 10-9s-4.477-9-10-9z"/>
		</svg>
	</a>
</footer>
<style>
	footer {
		padding: 3em 1em;
		background: var(--bg);
		color: var(--text-muted);
		text-align: center;
		border-top: 1px solid var(--border-color);
		margin-top: 4em;
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		font-size: 0.9em;
	}
	
	.floating-tg-btn {
		position: fixed;
		bottom: 30px;
		right: 30px;
		width: 64px;
		height: 64px;
		background-color: #8b5cf6;
		color: white;
		border-radius: 50%;
		display: flex;
		justify-content: center;
		align-items: center;
		text-decoration: none;
		box-shadow: 0 4px 15px rgba(139, 92, 246, 0.4);
		z-index: 1000;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.floating-tg-btn:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 20px rgba(139, 92, 246, 0.6);
	}
	.floating-tg-btn svg {
		flex-shrink: 0;
	}
</style>
