---
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="footer-legal">
			<a href="https://lumeninsights.kr/terms" target="_blank" rel="noopener noreferrer">이용약관</a>
			<span class="divider">|</span>
			<a href="https://lumeninsights.kr/privacy" target="_blank" rel="noopener noreferrer"><strong>개인정보처리방침</strong></a>
			<span class="divider">|</span>
			<a href="mailto:dhlumen@gmail.com">제휴 문의</a>
		</div>
		<div class="footer-copyright">
			&copy; {today.getFullYear()} Lumen Insights. All rights reserved.
		</div>
	</div>
	
	<!-- Floating Chat Button -->
	<a href="https://t.me/LumenInsightsBot" target="_blank" rel="noopener noreferrer" class="floating-tg-btn" title="텔레그램 봇 문의하기">
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="32" height="32">
		  <path d="M12 3c5.5 0 10 3.58 10 8s-4.5 8-10 8c-1.24 0-2.43-.18-3.53-.5C5.55 21 2 21 2 21c2.33-2.33 2.7-3.9 2.75-4.5C3.05 15.07 2 13.13 2 11c0-4.42 4.5-8 10-8zm-3 9c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm3 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm3 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/>
		</svg>
	</a>
</footer>
<style>
	footer {
		padding: 3em 1em;
		background: var(--bg);
		color: var(--text-muted);
		text-align: center;
		border-top: 1px solid var(--border-color);
		margin-top: 4em;
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		font-size: 0.9em;
		display: flex;
		flex-direction: column;
		gap: 1em;
	}
	.footer-legal {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 10px;
		font-size: 0.95em;
	}
	.footer-legal a {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.footer-legal a:hover {
		color: var(--text-main);
	}
	.footer-legal .divider {
		color: var(--border-color);
		font-size: 0.8em;
	}
	.footer-copyright {
		opacity: 0.8;
	}
	
	.floating-tg-btn {
		position: fixed;
		bottom: 30px;
		right: 30px;
		width: 64px;
		height: 64px;
		background-color: #8b5cf6;
		color: white;
		border-radius: 50%;
		display: flex;
		justify-content: center;
		align-items: center;
		text-decoration: none;
		box-shadow: 0 4px 15px rgba(139, 92, 246, 0.4);
		z-index: 1000;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.floating-tg-btn:hover {
		transform: translateY(-4px);
		box-shadow: 0 6px 20px rgba(139, 92, 246, 0.6);
	}
	.floating-tg-btn svg {
		flex-shrink: 0;
	}
</style>
