---
const today = new Date();
---

<footer>
	<div class="footer-content">
		&copy; {today.getFullYear()} Lumen Insights. All rights reserved.
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em;
		background: var(--bg);
		color: var(--text-muted);
		text-align: center;
		border-top: 1px solid var(--border-color);
		margin-top: 4em;
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		font-size: 0.9em;
	}
</style>
