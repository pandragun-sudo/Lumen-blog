---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="nav-right">
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
			<a href="https://lumeninsights.kr/?utm_source=lumen_blog&utm_medium=referral&utm_campaign=blog_header" target="_blank" rel="noopener noreferrer" class="header-premium-btn">
				<span class="rocket">🚀</span> Lumen Insights
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
		font-weight: 700;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--text-main);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		height: 70px;
	}
	.internal-links {
		display: flex;
		gap: 2em;
	}
	.internal-links a {
		padding: 1em 0;
		color: var(--text-muted);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95em;
		transition: color 0.2s ease;
	}
	.internal-links a:hover {
		color: var(--text-main);
	}
	.internal-links a.active {
		color: var(--text-main);
		border-bottom-color: var(--text-main);
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 2em;
	}
	.header-premium-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		background: #111827;
		color: #ffffff !important;
		padding: 8px 16px;
		border-radius: 8px;
		font-weight: 700;
		font-size: 0.85em;
		text-decoration: none !important;
		border: 1px solid #374151;
		transition: all 0.2s ease;
		box-shadow: 0 2px 8px rgba(17, 24, 39, 0.2);
	}
	.header-premium-btn:hover {
		background: #1f2937;
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(17, 24, 39, 0.3);
	}
	.rocket {
		font-size: 1.1em;
	}
	@media (max-width: 720px) {
		nav {
			flex-direction: column;
			height: auto;
			padding: 1em 0;
			gap: 1em;
		}
		.nav-right {
			flex-direction: column;
			gap: 1em;
		}
		.internal-links {
			gap: 1.5em;
		}
	}
</style>
