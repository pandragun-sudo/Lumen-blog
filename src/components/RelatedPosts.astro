---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

export interface Props {
	currentTitle?: string;
}

const { currentTitle } = Astro.props;

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const relatedPosts = posts.filter(post => post.data.title !== currentTitle).slice(0, 3);
---

{relatedPosts.length > 0 && (
	<section class="related-posts-section">
		<h3>🔥 이번 주 인기글 추천</h3>
		<div class="posts-grid">
			{
				relatedPosts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-card">
						{post.data.heroImage ? (
							<div class="img-container">
								<img src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src} alt="" />
							</div>
						) : (
							<div class="img-container placeholder-img"></div>
						)}
						<div class="content">
							<h4 class="title">{post.data.title}</h4>
							<p class="date">
								<FormattedDate date={post.data.pubDate} />
							</p>
						</div>
					</a>
				))
			}
		</div>
	</section>
)}

<style>
	.related-posts-section {
		margin-top: 3rem;
		padding-top: 3rem;
		border-top: 1px solid #e2e8f0;
	}
	.related-posts-section h3 {
		font-size: 1.5rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		color: #1e293b;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.5rem;
	}
	.post-card {
		display: flex;
		flex-direction: column;
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		overflow: hidden;
		text-decoration: none !important;
		color: inherit;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.post-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 10px 25px rgba(0,0,0,0.08);
	}
	.img-container {
		width: 100%;
		height: 140px;
		overflow: hidden;
	}
	.img-container img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}
	.post-card:hover .img-container img {
		transform: scale(1.05);
	}
	.placeholder-img {
		background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
	}
	.content {
		padding: 1rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}
	.title {
		font-size: 1.05rem;
		font-weight: 600;
		margin: 0 0 0.5rem 0;
		line-height: 1.4;
		color: #0f172a;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.date {
		margin: auto 0 0 0;
		font-size: 0.85rem;
		color: #64748b;
	}
	@media (max-width: 768px) {
		.posts-grid {
			grid-template-columns: 1fr;
		}
		.img-container {
			height: 180px;
		}
	}
</style>
